# ============================================================
# PRODUÇÃO — mdaas.shareinvestimentos.com.br
# Copie para .env no servidor e preencha os valores reais.
# NUNCA commite o .env com valores reais!
# ============================================================

# Gerar: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

DEBUG=False
ALLOWED_HOSTS=mdaas.shareinvestimentos.com.br,api
DJANGO_SETTINGS_MODULE=config.settings.production

# Banco de dados
DB_NAME=sharepos_prod
DB_USER=sharepos_app
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Gerar: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Gerar: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

FRONTEND_URL=https://mdaas.shareinvestimentos.com.br

# Opcional: DSN do Sentry para monitoramento de erros
SENTRY_DSN=
